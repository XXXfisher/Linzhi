---
import "../../styles/global.css";

// 项目信息对象：Where Plants Listen
const project = {
  title: "Where Plants Listen",
  subtitle: "A multi-sensory journey where botanical life breathes through the rhythm of sound.",
  backLink: "/",
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{project.title} | Portfolio</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800&family=Playfair+Display:italic&display=swap" rel="stylesheet">
  </head>
  <body>
    <div class="cursor"></div> 

    <main class="detail-page">
      <a class="back-link" href={project.backLink}>
        <span class="arrow">←</span> Back to Works
      </a>

      <header class="detail-header">
        <h1 class="detail-title">{project.title}</h1>
        <p class="detail-subtitle">{project.subtitle}</p>
      </header>

      <div class="carousel-viewport group">
        <div class="carousel-container" id="carousel">
          <img class="carousel-item" src="/images/WPL/COVER.png" alt="Botanical Audio-Reactive Scene" />
          <img class="carousel-item" src="/images/WPL/f1.jpg" alt="Unreal Engine Environment" />
          <img class="carousel-item" src="/images/WPL/f2.jpg" alt="Frequency Extraction Details" />
        </div>
        
        <button class="nav-btn prev" id="prevBtn">〈</button>
        <button class="nav-btn next" id="nextBtn">〉</button>
        
        <div class="carousel-dots" id="dots"></div>
      </div>

      <div class="content-wrapper">
        <section class="detail-section">
          <h2>The Artistic Concept</h2>
          <p class="section-text">
            <strong>Where Plants Listen</strong> is a technical exploration into the synergy of sound and life. 
            By mapping real-time audio frequencies to organic plant behaviors in <strong>Unreal Engine</strong>, 
            the project creates a world where foliage responds dynamically to music. This interactive landscape 
            transforms passive game environments into living, breathing entities that trigger deep <strong>sensory resonance</strong>.
          </p>

                    
          <div class="video-wrapper">
            <iframe 
              src="https://www.youtube.com/embed/8O3QA2VJ5ew"
               title="YouTube video player"
               allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
               allowfullscreen>
            </iframe>
          </div>
        </section>

        <section class="detail-section">
          <h2>Technical Mapping & Audio Logic</h2>
          <div class="derivation-box" style="width: 100%; padding: 40px; background: rgba(52, 211, 153, 0.05); border: 1px dashed var(--accent-color); border-radius: 20px; margin: 20px 0; text-align: center;">
             <img src="/images/WPL/UE.png" alt="Technical Derivation" style="max-width: 100%; height: auto; border-radius: 12px;" />
             <p style="color: var(--text-muted); font-size: 0.9rem; margin-top: 15px; font-style: italic;">
               [ Figure: Spectral Data to Vertex Animation Offset Mapping ]
             </p>
          </div>
        </section>

        <section class="detail-section">
          <h2>Core Integration Pillars</h2>
          <div class="algo-grid">
            <div class="algo-card">
              <h3>Real-time FFT Analysis</h3>
              <p>Implemented high-frequency extraction within Unreal Engine, isolating sub-bass and lead melodies to drive distinct botanical growth and movement curves.</p>
            </div>
            <div class="algo-card">
              <h3>DAW Synchronicity</h3>
              <p>FL Studio was utilized as the primary DAW host for audio production, allowing for surgical precision in stem-based animation triggers and rhythmic timing.</p>
            </div>
          </div>
        </section>

        <section class="detail-section">
          <h2>Experience Highlights</h2>
          <ul class="highlight-list">
            <li><strong>Dynamic Plant Behavior:</strong> Real-time scaling, rotation, and color shifts driven by spectral intensity.</li>
            <li><strong>Multi-Sensory Cohesion:</strong> Bridging the gap between auditory perception and visual stimuli in interactive game scenes.</li>
            <li><strong>Optimized Performance:</strong> Efficient vertex-displacement techniques ensuring smooth 60FPS visuals during complex audio-reactive sequences.</li>
          </ul>
        </section>
      </div>
    </main>

    <style>
      :root {
        /* 基于植物与音频主题设计的清新/科技配色 */
        --accent-color: #34d399; /* 翠绿色 */
        --secondary-accent: #06b6d4; /* 青蓝色 */
        --bg-color: #050508; /* 深黑背景 */
        --text-main: #f3f4f6; 
        --text-muted: #9ca3af;
        --card-bg: rgba(52, 211, 153, 0.08); /* 极浅的翠绿半透明 */
      }

      body {
        background-color: var(--bg-color);
        background-image: radial-gradient(circle at 50% -20%, #064e3b 0%, var(--bg-color) 75%);
        color: var(--text-main);
        font-family: 'Inter', sans-serif;
        margin: 0;
        line-height: 1.6;
      }

      .detail-page { max-width: 900px; margin: 0 auto; padding: 80px 24px; }

      .back-link {
        display: inline-block;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.9rem;
        margin-bottom: 40px;
        transition: color 0.3s ease;
      }
      .back-link:hover { color: var(--accent-color); }

      .detail-title {
        font-size: clamp(2.5rem, 8vw, 4.5rem);
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 16px;
        /* 植物主题渐变文字 */
        background: linear-gradient(to right, #fff, var(--accent-color), var(--secondary-accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .detail-subtitle {
        font-size: 1.25rem;
        color: var(--text-muted);
        max-width: 650px;
        margin-bottom: 60px;
        font-family: 'Playfair Display', serif;
        font-style: italic;
      }

      .section-text { font-size: 1.15rem; opacity: 0.9; }

      .detail-section h2 {
        font-size: 1.6rem;
        color: #fff;
        margin-bottom: 24px;
        border-left: 3px solid var(--accent-color);
        padding-left: 20px;
      }

      .algo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }

      .algo-card {
        background: var(--card-bg);
        padding: 30px;
        border-radius: 16px;
        border: 1px solid rgba(52, 211, 153, 0.15);
        backdrop-filter: blur(10px);
        transition: transform 0.4s ease;
      }
      .algo-card:hover { transform: translateY(-5px); border-color: var(--accent-color); }

      .algo-card h3 { font-size: 1rem; color: var(--accent-color); text-transform: uppercase; letter-spacing: 0.1em; }
      .algo-card p { color: var(--text-muted); font-size: 0.95rem; }

      .highlight-list { list-style: none; padding: 0; }
      .highlight-list li {
        margin-bottom: 18px;
        padding-left: 32px;
        position: relative;
        opacity: 0.85;
      }
      /* 使用菱形符号契合科技植物感 */
      .highlight-list li::before {
        content: "◆";
        position: absolute;
        left: 0;
        color: var(--accent-color);
        font-size: 1.1rem;
      }

      .carousel-viewport {
        position: relative; width: 100%; margin-bottom: 80px;
        border-radius: 20px; overflow: hidden;
        box-shadow: 0 30px 60px -12px rgba(0,0,0,0.5);
      }
      .carousel-container { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; scrollbar-width: none; }
      .carousel-container::-webkit-scrollbar { display: none; }
      .carousel-item { flex: 0 0 100%; height: 500px; object-fit: cover; scroll-snap-align: start; }
      
      .nav-btn {
        position: absolute; top: 50%; transform: translateY(-50%);
        background: rgba(255, 255, 255, 0.1); color: white; border: 1px solid rgba(255,255,255,0.2);
        width: 50px; height: 50px; border-radius: 50%; cursor: pointer;
        opacity: 0; transition: all 0.4s; z-index: 10;
      }
      .carousel-viewport:hover .nav-btn { opacity: 1; }
      .prev { left: 24px; }
      .next { right: 24px; }

      .carousel-dots { position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%); display: flex; gap: 12px; }
      .dot { width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.2); cursor: pointer; }
      .dot.active { background: var(--accent-color); transform: scale(1.3); box-shadow: 0 0 10px var(--accent-color); }

      /* 配合植物风格的自定义光标 */
      .cursor {
        width: 24px; height: 24px; background: var(--accent-color); border-radius: 50%;
        position: fixed; pointer-events: none; z-index: 9999;
        mix-blend-mode: screen; transition: transform 0.15s ease-out;
        transform: translate(-50%, -50%);
        filter: blur(2px);
      }
      .cursor-active { transform: translate(-50%, -50%) scale(2.5); background: var(--secondary-accent); }

      @media (max-width: 640px) { .algo-grid { grid-template-columns: 1fr; } .carousel-item { height: 350px; } }
    </style>

    <script>
      // 光标交互逻辑
      const cursor = document.querySelector(".cursor") as HTMLElement;
      window.addEventListener("mousemove", (e) => {
        cursor.style.left = `${e.clientX}px`;
        cursor.style.top = `${e.clientY}px`;
      });

      // 轮播图逻辑
      const carousel = document.getElementById('carousel') as HTMLElement;
      const prevBtn = document.getElementById('prevBtn');
      const nextBtn = document.getElementById('nextBtn');
      const dotsContainer = document.getElementById('dots');
      const items = document.querySelectorAll('.carousel-item');

      if (carousel && dotsContainer) {
        items.forEach((_, i) => {
          const dot = document.createElement('div');
          dot.classList.add('dot');
          if (i === 0) dot.classList.add('active');
          dot.addEventListener('click', () => {
            carousel.scrollTo({ left: carousel.offsetWidth * i, behavior: 'smooth' });
          });
          dotsContainer.appendChild(dot);
        });

        nextBtn?.addEventListener('click', () => carousel.scrollBy({ left: carousel.offsetWidth, behavior: 'smooth' }));
        prevBtn?.addEventListener('click', () => carousel.scrollBy({ left: -carousel.offsetWidth, behavior: 'smooth' }));

        carousel.addEventListener('scroll', () => {
          const index = Math.round(carousel.scrollLeft / carousel.offsetWidth);
          const dots = document.querySelectorAll('.dot');
          dots.forEach((dot, i) => dot.classList.toggle('active', i === index));
        });
      }

      // 悬停反馈
      const interactiveElements = document.querySelectorAll("a, img, button, .algo-card, .derivation-box");
      interactiveElements.forEach((el) => {
        el.addEventListener("mouseenter", () => cursor?.classList.add("cursor-active"));
        el.addEventListener("mouseleave", () => cursor?.classList.remove("cursor-active"));
      });
    </script>
  </body>
</html>